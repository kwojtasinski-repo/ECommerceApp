{
  "$schema": "https://aka.ms/copilot-mcp-schema",
  "servers": {
    "ecommerceapp-rag": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run", "--rm", "--interactive",
        "--volume", "${workspaceFolder}:/workspace",
        "--volume", "qdrant_data:/data/qdrant",
        "--env", "RAG_WORKSPACE=/workspace",
        "--env", "PYTHONUNBUFFERED=1",
        "rag-tools",
        "python", "/app/mcp_server.py"
      ]
    }
  }
}

