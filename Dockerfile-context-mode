# ─────────────────────────────────────────────────────────────────
# Stage 1: Build context-mode from source (pinned tag, auditable)
# ─────────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

# Build deps for native modules (better-sqlite3 fallback when node:sqlite is unavailable)
RUN apk add --no-cache git python3 make g++

# Clone exactly this tag — change it here on upgrade, nowhere else.
# v1.0.147+ required for CONTEXT_MODE_DIR support; bump to latest stable on rebuild.
ARG CONTEXT_MODE_TAG=v1.0.162
RUN git clone --depth 1 --branch ${CONTEXT_MODE_TAG} \
    https://github.com/mksglu/context-mode.git /build

WORKDIR /build
# NOTE: do NOT pass --ignore-scripts — better-sqlite3 needs its postinstall to compile.
# Upstream repo ships without a lockfile, so `npm install` instead of `npm ci`.
RUN npm install --omit=dev

# ─────────────────────────────────────────────────────────────────
# Stage 2: Minimal runtime image
# ─────────────────────────────────────────────────────────────────
FROM node:24-alpine

# Runtime CLI tools for sandbox shell analysis (ctx_execute/ctx_batch_execute).
RUN apk add --no-cache bash git jq python3 ripgrep py3-networkx py3-numpy py3-pandas py3-tabulate

# Non-root user — security hardening
RUN addgroup -S ctxmode && adduser -S ctxmode -G ctxmode

# Copy the built application
COPY --from=builder /build /app
COPY docker/context-mode/network-monitor.cjs /app/network-monitor.cjs

RUN mkdir -p /home/ctxmode/.context-mode \
 && printf '%s\n' '#!/bin/sh' 'set -eu' 'NODE_OPTS="${CONTEXT_MODE_NODE_OPTIONS:---no-experimental-sqlite}"' 'DEBUG_SCOPE="${CONTEXT_MODE_DEBUG:-context-mode}"' 'exec env NODE_OPTIONS="$NODE_OPTS" DEBUG="$DEBUG_SCOPE" node --require /app/network-monitor.cjs /app/cli.bundle.mjs "$@" 2>>/home/ctxmode/.context-mode/runtime.log' > /usr/local/bin/context-mode \
 && printf '%s\n' '#!/bin/sh' 'set -eu' 'LOG_FILE=/home/ctxmode/.context-mode/hooks.log' 'printf "%s context-mode-hook %s\n" "$(date -Iseconds)" "$*" >> "$LOG_FILE"' 'exec context-mode hook "$@" >>"$LOG_FILE" 2>&1' > /usr/local/bin/context-mode-hook \
 && chmod +x /usr/local/bin/context-mode \
 && chmod +x /usr/local/bin/context-mode-hook \
 && chown -R ctxmode:ctxmode /app /home/ctxmode/.context-mode

USER ctxmode
WORKDIR /workspace

# Runtime defaults: use better-sqlite3 path (disable node:sqlite experimental module)
# and keep context-mode scoped debug hooks available. Both are overrideable via
# docker-compose env / .env.context-mode.
ENV CONTEXT_MODE_NODE_OPTIONS="--no-experimental-sqlite" \
    CONTEXT_MODE_DEBUG="context-mode"

CMD ["sh", "-lc", "mkdir -p /home/ctxmode/.context-mode /tmp && touch /home/ctxmode/.context-mode/runtime.log /home/ctxmode/.context-mode/hooks.log /workspace/.ctx-network-alerts.log && echo \"context-mode container started\" && tail -n0 -F /home/ctxmode/.context-mode/runtime.log & tail -n0 -F /home/ctxmode/.context-mode/hooks.log & tail -n0 -F /workspace/.ctx-network-alerts.log & wait"]
