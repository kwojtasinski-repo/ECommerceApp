@using ECommerceApp.Application.Catalog.Products.ViewModels
@{ ViewData["Title"] = "Add Product"; }

<div class="container mt-4" style="max-width:600px">
    <h2>Add Product</h2>
    <form method="post" asp-action="Add">
        <div class="form-group">
            <label>Name</label>
            <input name="Name" class="form-control" required minlength="3" maxlength="150" />
        </div>
        <div class="form-group">
            <label>Cost</label>
            <input name="Cost" type="number" step="0.01" min="0.01" class="form-control" required />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea name="Description" class="form-control" rows="2" maxlength="300"></textarea>
        </div>
        <div class="form-group">
            <label>Category</label>
            <select name="CategoryId" class="form-control" required>
                <option value="">— select —</option>
                @foreach (CategoryVm cat in (ViewBag.Categories ?? new List<CategoryVm>()))
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
            <div class="mt-1">
                <a href="#" class="small" onclick="toggleNewCat(event)">＋ New category</a>
                <div id="new-cat-row" style="display:none" class="mt-2">
                    <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                        <input id="new-cat-name" type="text" class="form-control form-control-sm"
                               placeholder="Category name" maxlength="100" style="width:200px" />
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="createCategory()">Create</button>
                        <button type="button" class="btn btn-sm btn-link text-muted p-0" onclick="cancelNewCat()">Cancel</button>
                    </div>
                    <div id="new-cat-error" class="text-danger small"></div>
                </div>
            </div>
        </div>
        <div class="form-group">
            <label>Tags <small class="text-muted">(comma-separated; new tags will be created automatically)</small></label>
            <input name="Tags" class="form-control" placeholder="e.g. sale, new-arrival, featured"
                   list="tag-hints" autocomplete="off" />
            <datalist id="tag-hints">
                @foreach (ProductTagVm tag in (ViewBag.TagHints ?? new List<ProductTagVm>()))
                {
                    <option value="@tag.Name" />
                }
            </datalist>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

<script>
    function toggleNewCat(e) {
        e.preventDefault();
        var row = document.getElementById('new-cat-row');
        row.style.display = row.style.display === 'none' ? '' : 'none';
        if (row.style.display !== 'none') document.getElementById('new-cat-name').focus();
    }
    function cancelNewCat() {
        document.getElementById('new-cat-row').style.display = 'none';
        document.getElementById('new-cat-name').value = '';
        document.getElementById('new-cat-error').textContent = '';
    }
    async function createCategory() {
        var name = document.getElementById('new-cat-name').value.trim();
        var errEl = document.getElementById('new-cat-error');
        if (!name) { errEl.textContent = 'Name is required.'; return; }
        errEl.textContent = '';
        var resp = await fetch('/v2/categories/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name })
        });
        if (!resp.ok) { errEl.textContent = 'Could not create category.'; return; }
        var data = await resp.json();
        var sel = document.querySelector('select[name="CategoryId"]');
        var opt = document.createElement('option');
        opt.value = data.id;
        opt.textContent = data.name;
        sel.add(opt);
        sel.value = data.id;
        cancelNewCat();
    }
</script>

