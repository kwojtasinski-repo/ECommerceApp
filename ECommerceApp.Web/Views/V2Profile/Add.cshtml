@{ ViewData["Title"] = "Add User Profile"; }

<div class="container mt-4" style="max-width:650px">
    <h2>Add User Profile</h2>
    <form method="post" asp-action="Add">
        <div class="form-group">
            <label>User Id <small class="text-muted">(ASP.NET Identity user GUID)</small></label>
            <input name="userId" class="form-control" required />
        </div>
        <div class="form-row">
            <div class="form-group col-md-6">
                <label>First Name</label>
                <input name="firstName" class="form-control" required maxlength="300" />
            </div>
            <div class="form-group col-md-6">
                <label>Last Name</label>
                <input name="lastName" class="form-control" required maxlength="300" />
            </div>
        </div>
        <div class="form-group">
            <label>Email</label>
            <input name="email" type="email" class="form-control" required maxlength="300" />
        </div>
        <div class="form-group">
            <label>Phone Number</label>
            <input name="phoneNumber" class="form-control" required maxlength="50" />
        </div>
        <div class="form-group form-check">
            <input name="isCompany" type="checkbox" class="form-check-input" id="isCompany" />
            <label class="form-check-label" for="isCompany">Is Company</label>
        </div>
        <div class="form-group">
            <label>Company Name</label>
            <input name="companyName" class="form-control" maxlength="300" />
        </div>
        <div class="form-group">
            <label>NIP</label>
            <input name="nip" class="form-control" maxlength="50" />
        </div>

        <hr />
        <h5>Address <small class="text-muted">(required)</small></h5>
        <div class="form-row">
            <div class="form-group col-md-8">
                <label>Street</label>
                <input name="street" class="form-control" required maxlength="200" />
            </div>
            <div class="form-group col-md-4">
                <label>Building No.</label>
                <input name="buildingNumber" class="form-control" required maxlength="20" />
            </div>
        </div>
        <div class="form-row">
            <div class="form-group col-md-3">
                <label>Flat No. <small class="text-muted">(opt.)</small></label>
                <input name="flatNumber" type="number" class="form-control" min="1" />
            </div>
            <div class="form-group col-md-4">
                <label>ZIP Code</label>
                <input name="zipCode" class="form-control" required maxlength="12" />
            </div>
            <div class="form-group col-md-5">
                <label>City</label>
                <input name="city" class="form-control" required maxlength="300" />
            </div>
        </div>
        <div class="form-group">
            <label>Country <small class="text-muted">(ISO 2-letter code, e.g. PL)</small></label>
            <input name="country" class="form-control" required maxlength="2" minlength="2" placeholder="e.g. PL" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
