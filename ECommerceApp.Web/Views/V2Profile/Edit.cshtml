@using ECommerceApp.Application.AccountProfile.ViewModels
@model UserProfileDetailsVm
@{ ViewData["Title"] = "Edit Profile"; }

<div class="container mt-4" style="max-width:900px">
    <h2>Edit Profile — <strong>@Model.FirstName @Model.LastName</strong></h2>
    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
    }
    <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
        <div class="form-row">
            <div class="form-group col-md-6">
                <label>First Name</label>
                <input name="firstName" class="form-control" value="@Model.FirstName" required maxlength="300" />
            </div>
            <div class="form-group col-md-6">
                <label>Last Name</label>
                <input name="lastName" class="form-control" value="@Model.LastName" required maxlength="300" />
            </div>
        </div>
        <div class="form-group form-check">
            <input name="isCompany" type="checkbox" class="form-check-input" id="isCompany" @(Model.IsCompany ? "checked" : "") />
            <label class="form-check-label" for="isCompany">Is Company</label>
        </div>
        <div class="form-group">
            <label>Company Name</label>
            <input name="companyName" class="form-control" value="@Model.CompanyName" maxlength="300" />
        </div>
        <div class="form-group">
            <label>NIP</label>
            <input name="nip" class="form-control" value="@Model.NIP" maxlength="50" />
        </div>
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </form>

    <hr class="mt-4" />
    <h5>Addresses</h5>
    @if (Model.Addresses.Count == 0)
    {
        <p class="text-muted small">No addresses on file.</p>
    }
    else
    {
        <table class="table table-sm table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Street</th><th>Building</th><th>Flat</th><th>ZIP</th><th>City</th><th>Country</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var addr in Model.Addresses)
                {
                    <tr>
                        <td>@addr.Street</td>
                        <td>@addr.BuildingNumber</td>
                        <td>@(addr.FlatNumber.HasValue ? addr.FlatNumber.ToString() : "—")</td>
                        <td>@addr.ZipCode</td>
                        <td>@addr.City</td>
                        <td>@addr.Country</td>
                        <td>
                            @if (Model.Addresses.Count > 1)
                            {
                                <form method="post" asp-action="RemoveAddress" asp-route-id="@Model.Id" asp-route-addressId="@addr.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small" title="Cannot remove the last address">Last</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <button class="btn btn-sm btn-outline-primary mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#addAddressForm" aria-expanded="false">
        + Add Address
    </button>
    <div class="collapse" id="addAddressForm">
        <div class="card card-body mb-3">
            <form method="post" asp-action="AddAddress" asp-route-id="@Model.Id">
                <div class="form-row">
                    <div class="form-group col-md-8">
                        <label>Street</label>
                        <input name="street" class="form-control form-control-sm" required maxlength="200" />
                    </div>
                    <div class="form-group col-md-4">
                        <label>Building No.</label>
                        <input name="buildingNumber" class="form-control form-control-sm" required maxlength="20" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-3">
                        <label>Flat No. <small>(opt.)</small></label>
                        <input name="flatNumber" type="number" class="form-control form-control-sm" min="1" />
                    </div>
                    <div class="form-group col-md-4">
                        <label>ZIP Code</label>
                        <input name="zipCode" class="form-control form-control-sm" required maxlength="12" />
                    </div>
                    <div class="form-group col-md-5">
                        <label>City</label>
                        <input name="city" class="form-control form-control-sm" required maxlength="300" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Country <small>(ISO 2-letter, e.g. PL)</small></label>
                    <input name="country" class="form-control form-control-sm" required maxlength="2" minlength="2" placeholder="e.g. PL" />
                </div>
                <button type="submit" class="btn btn-sm btn-primary">Add</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-toggle="collapse" data-bs-target="#addAddressForm">Cancel</button>
            </form>
        </div>
    </div>
</div>
