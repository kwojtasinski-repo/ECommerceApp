@using ECommerceApp.Application.Supporting.TimeManagement.Models
@model RegisterJobVm
@{ ViewData["Title"] = "Register Job"; }

<div class="container mt-4" style="max-width:520px">
    <h2>Register Cron Job <small class="text-muted">test/dev</small></h2>
    <form method="post" asp-action="Register">
        <div class="form-group">
            <label>Job Name</label>
            <input name="JobName" class="form-control" required maxlength="100"
                   placeholder="e.g. CurrencyDownloader" value="@Model.JobName" />
            <small class="form-text text-muted">Must match <code>IScheduledTask.TaskName</code> exactly.</small>
        </div>
        <div class="form-group">
            <label>Cron Schedule</label>
            <input name="Schedule" class="form-control" required maxlength="100"
                   placeholder="e.g. 15 12 * * *" value="@Model.Schedule" />
            <small class="form-text text-muted">Standard 5-part cron (minute hour day month weekday). Uses Cronos — no seconds field.</small>
        </div>
        <div class="form-group">
            <label>Max Retries</label>
            <input name="MaxRetries" type="number" class="form-control" min="0" max="10"
                   value="@Model.MaxRetries" required />
        </div>
        <div class="form-group">
            <label>Time Zone ID <span class="text-muted">(optional)</span></label>
            <input name="TimeZoneId" class="form-control" maxlength="100"
                   placeholder="e.g. Europe/Warsaw  — leave blank for UTC" value="@Model.TimeZoneId" />
        </div>
        <button type="submit" class="btn btn-primary">Register</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
