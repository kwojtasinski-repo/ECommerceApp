@using ECommerceApp.Application.Supporting.TimeManagement.Models
@model IReadOnlyList<JobStatusSummary>
@{ ViewData["Title"] = "Scheduled Jobs v2"; }

<div class="container mt-4">
    <h2>Scheduled Jobs <small class="text-muted">TimeManagementDbContext</small></h2>
    <a asp-action="Register" class="btn btn-outline-primary btn-sm mb-3">+ Register Recurring Job</a>
    <a asp-action="ScheduleDeferred" class="btn btn-outline-warning btn-sm mb-3 ms-2">+ Schedule Deferred Job</a>
    <a asp-action="DeferredQueue" class="btn btn-outline-secondary btn-sm mb-3 ms-2">Deferred Queue</a>
    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
    }
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr><th>Job Name</th><th>Type</th><th>Schedule</th><th>Enabled</th><th>Last Run</th><th>Next Run</th><th>Last Result</th><th style="width:220px"></th></tr>
        </thead>
        <tbody>
            @foreach (var j in Model)
            {
                <tr>
                    <td><strong>@j.JobName</strong></td>
                    <td>
                        @if (j.Schedule != null)
                        {
                            <span class="badge text-bg-info">Recurring</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">Deferred</span>
                        }
                    </td>
                    <td><code>@(j.Schedule ?? "—")</code></td>
                    <td>
                        @if (j.IsEnabled)
                        {
                            <span class="badge text-bg-success">Enabled</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Disabled</span>
                        }
                    </td>
                    <td>@(j.NeverRun ? "Never" : j.LastRunAt?.ToString("g"))</td>
                    <td>@(j.NextRunAt.HasValue ? j.NextRunAt.Value.ToString("g") : "—")</td>
                    <td>
                        @if (!j.NeverRun)
                        {
                            if (j.LastSucceeded == true)
                            {
                                <span class="badge text-bg-success">OK</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger" title="@j.LastMessage">Failed</span>
                            }
                        }
                    </td>
                    <td>
                        <form method="post" asp-action="Trigger" asp-route-jobName="@j.JobName" class="d-inline">
                            <button class="btn btn-sm btn-primary" title="Force run now">
                                <i class="fas fa-play"></i> Run
                            </button>
                        </form>
                        <a asp-action="History" asp-route-jobName="@j.JobName" class="btn btn-sm btn-info">History</a>
                        @if (j.IsEnabled)
                        {
                            <form method="post" asp-action="Disable" asp-route-jobName="@j.JobName" class="d-inline">
                                <button class="btn btn-sm btn-secondary">Disable</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-action="Enable" asp-route-jobName="@j.JobName" class="d-inline">
                                <button class="btn btn-sm btn-success">Enable</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
