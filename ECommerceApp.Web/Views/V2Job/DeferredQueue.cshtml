@using ECommerceApp.Application.Supporting.TimeManagement.Models
@using ECommerceApp.Domain.Supporting.TimeManagement
@model IReadOnlyList<DeferredJobQueueVm>
@{ ViewData["Title"] = "Deferred Job Queue"; }

<div class="container mt-4">
    <h2>Deferred Job Queue <small class="text-muted">read-only</small></h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">&larr; Back to Jobs</a>
    <a asp-action="ScheduleDeferred" class="btn btn-outline-warning btn-sm mb-3 ms-2">+ Schedule Deferred Job</a>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No deferred jobs in the queue.</div>
    }
    else
    {
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Job Name</th>
                    <th>Entity ID</th>
                    <th>Run At (UTC)</th>
                    <th>Status</th>
                    <th>Retries</th>
                    <th>Scheduled At (UTC)</th>
                    <th>Error</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var d in Model)
                {
                    <tr>
                        <td><code>@d.Id</code></td>
                        <td><strong>@d.JobName</strong></td>
                        <td><code>@d.EntityId</code></td>
                        <td>@d.RunAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @switch (d.Status)
                            {
                                case DeferredJobStatus.Pending:
                                    <span class="badge text-bg-primary">Pending</span>
                                    break;
                                case DeferredJobStatus.Running:
                                    <span class="badge text-bg-warning">Running</span>
                                    break;
                                case DeferredJobStatus.DeadLetter:
                                    <span class="badge text-bg-danger">DeadLetter</span>
                                    break;
                            }
                        </td>
                        <td>@d.RetryCount / @d.MaxRetries</td>
                        <td>@d.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (d.ErrorMessage != null)
                            {
                                <span title="@d.ErrorMessage" class="text-danger" style="cursor:help">&#9888; @(d.ErrorMessage.Length > 40 ? d.ErrorMessage[..40] + "…" : d.ErrorMessage)</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <small class="text-muted">Rows ordered by scheduled run time. Successful jobs are deleted; only pending, running, and dead-letter rows appear here.</small>
    }
</div>
