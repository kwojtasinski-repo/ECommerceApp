@using ECommerceApp.Application.Inventory.Availability.ViewModels
@model StockOverviewVm
@{ ViewData["Title"] = "Przegląd stanu magazynu"; }

<div class="container mt-4">
    <h2>Przegląd stanu magazynu</h2>

    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @msg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>ID produktu</th>
                <th>Nazwa</th>
                <th>Status</th>
                <th>Stan</th>
                <th>Zarezerwowane</th>
                <th>Dostępne</th>
                <th>Oczekująca korekta</th>
                <th style="width:100px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.ProductName</td>
                    <td>
                        @if (item.IsDigital)
                        {
                            <span class="badge text-bg-info">Cyfrowy</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">@item.CatalogStatus</span>
                        }
                    </td>
                    <td>@item.Quantity</td>
                    <td>@item.ReservedQuantity</td>
                    <td>
                        @if (item.AvailableQuantity > 0)
                        {
                            <span class="text-success fw-bold">@item.AvailableQuantity</span>
                        }
                        else
                        {
                            <span class="text-danger">@item.AvailableQuantity</span>
                        }
                    </td>
                    <td>
                        @if (item.HasPendingAdjustment)
                        {
                            <span class="badge text-bg-warning">→ @item.PendingNewQuantity</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                data-bs-toggle="modal"
                                data-bs-target="#adjustModal"
                                data-productid="@item.ProductId"
                                data-productname="@item.ProductName"
                                data-quantity="@item.Quantity">
                            Koryguj
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @{
        var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    }
    <div class="d-flex justify-content-between align-items-center">
        <small class="text-muted">Łącznie: @Model.TotalCount pozycji</small>
        <div>
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize"
                   class="btn btn-outline-secondary btn-sm">← Poprzednia</a>
            }
            <span class="mx-2">Strona @Model.Page / @totalPages</span>
            @if (Model.Page < totalPages)
            {
                <a asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize"
                   class="btn btn-outline-secondary btn-sm">Następna →</a>
            }
        </div>
    </div>
</div>

<!-- Adjust Modal -->
<div class="modal fade" id="adjustModal" tabindex="-1" role="dialog" aria-labelledby="adjustModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="adjustModalLabel">Korekta stanu magazynu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zamknij"></button>
            </div>
            <form asp-action="Adjust" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <p>Produkt: <strong id="adjustProductName"></strong></p>
                    <p>Obecny stan: <strong id="adjustCurrentQty"></strong></p>
                    <input type="hidden" name="productId" id="adjustProductId" />
                    <div class="form-group">
                        <label for="adjustNewQty">Nowy stan magazynowy</label>
                        <input type="number" class="form-control" name="newQuantity" id="adjustNewQty" min="0" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-primary">Zaplanuj korektę</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#adjustModal').on('show.bs.modal', function (event) {
            var btn = $(event.relatedTarget);
            $('#adjustProductId').val(btn.data('productid'));
            $('#adjustProductName').text(btn.data('productname'));
            $('#adjustCurrentQty').text(btn.data('quantity'));
            $('#adjustNewQty').val('');
        });
    </script>
}
