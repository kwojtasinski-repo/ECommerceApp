@using ECommerceApp.Application.Supporting.Currencies.ViewModels
@model CreateCurrencyFormVm
@{ ViewData["Title"] = "Add Currency"; }

<div class="container mt-4" style="max-width:500px">
    <h2>Add Currency</h2>
    <form method="post" asp-action="Add">
        <div class="form-group">
            <label asp-for="Code">Code <small class="text-muted">(ISO 4217, e.g. EUR, USD, PLN)</small></label>
            <input asp-for="Code" class="form-control"
                   data-val-iso4217="true" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Description"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>


@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
