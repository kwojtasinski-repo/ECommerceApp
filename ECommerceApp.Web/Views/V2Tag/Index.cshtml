@using ECommerceApp.Application.Catalog.Products.ViewModels
@model System.Collections.Generic.List<TagWithUsageVm>
@{ ViewData["Title"] = "Tags"; }

<div class="container mt-4">
    <h2>Tags</h2>
    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show">@msg<button type="button" class="close" data-dismiss="alert">&times;</button></div>
    }
    <a asp-action="Add" class="btn btn-primary mb-3"><i class="fas fa-plus"></i> Add Tag</a>
    <table class="table table-bordered table-sm">
        <thead class="thead-light">
            <tr><th>Id</th><th>Name</th><th>Slug</th><th>Used in products</th><th style="width:160px"></th></tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Id</td>
                    <td>@t.Name</td>
                    <td>@t.Slug</td>
                    <td>
                        @if (t.TotalProductCount == 0)
                        {
                            <span class="text-muted">—</span>
                        }
                        else
                        {
                            <span class="small">@string.Join(", ", t.TopProductNames)</span>
                            @if (t.HasMore)
                            {
                                <span class="badge badge-secondary ml-1">@t.TotalProductCount+</span>
                            }
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form method="post" asp-action="Delete" asp-route-id="@t.Id" class="d-inline">
                            <button class="btn btn-sm btn-danger" onclick="return confirm('Delete tag and all its product assignments?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
