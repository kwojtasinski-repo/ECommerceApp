@using ECommerceApp.Application.Catalog.Products.ViewModels
@model ProductTagVm
@{ ViewData["Title"] = "Edit Tag"; }

<div class="container mt-4" style="max-width:500px">
    <h2>Edit Tag — <strong>@Model.Name</strong></h2>
    <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
        <div class="form-group">
            <label>Name</label>
            <input name="Name" class="form-control" value="@Model.Name" required maxlength="50" />
        </div>
        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
