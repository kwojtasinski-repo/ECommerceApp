@using ECommerceApp.Domain.Model
@using ECommerceApp.Application.Permissions
@using ECommerceApp.Application.Catalog.Products.Services
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ICategoryService CategoryService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerceApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/fontawesome.min.css" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/brands.min.css">
    <link rel="stylesheet" href="~/lib/fontawesome/css/solid.min.css">
    <link rel="stylesheet" href="~/lib/tom-select/css/tom-select.bootstrap5.min.css" />
</head>
<body>
    <header>
        @{
            var categories = await CategoryService.GetAllCategories();
            var isSignedIn = SignInManager.IsSignedIn(User);
            var isMaintenanceRole = User.IsInRole(UserPermissions.Roles.Administrator)
                || User.IsInRole(UserPermissions.Roles.Manager)
                || User.IsInRole(UserPermissions.Roles.Service);
            var isManagingRole = User.IsInRole(UserPermissions.Roles.Administrator)
                || User.IsInRole(UserPermissions.Roles.Manager);
        }
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container">
                <a class="navbar-brand navbar-title-app" asp-area="" asp-controller="Home" asp-action="Index">ECommerceApp</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topbarCollapse"
                        aria-controls="topbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="topbarCollapse">
                    <form class="d-flex mx-auto" asp-area="" asp-controller="Item" asp-action="Index" method="get">
                        <div class="input-group">
                            <input name="searchString" type="text" class="form-control" placeholder="Szukaj produktów..." />
                            <div class="dropdown">
                                <button class="btn btn-outline-secondary dropdown-toggle" type="button" id="categoryFilterBtn" data-bs-toggle="dropdown">Kategoria</button>
                                <div class="dropdown-menu">
                                    @foreach (var cat in categories)
                                    {
                                        <a class="dropdown-item category-filter-item" href="#" data-type-id="@cat.Id">@cat.Name</a>
                                    }
                                </div>
                            </div>
                            <input type="hidden" name="typeId" id="searchTypeId" />
                            <button type="submit" class="btn btn-outline-secondary"><i class="fa-solid fa-magnifying-glass"></i></button>
                        </div>
                    </form>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (isSignedIn)
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link position-relative" asp-area="Presale" asp-controller="Checkout" asp-action="Cart">
                                    <i class="fas fa-shopping-cart fa-lg"></i>
                                    <span id="itemCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill text-bg-light"></span>
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userMenuToggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fa-solid fa-user fa-lg"></i>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuToggle">
                                @if (isSignedIn)
                                {
                                    <a class="dropdown-item" asp-area="Sales" asp-controller="Orders" asp-action="MyOrders">Moje zamówienia</a>
                                    <a class="dropdown-item" asp-area="Sales" asp-controller="Payments" asp-action="MyPayments">Moje płatności</a>
                                    <a class="dropdown-item" asp-area="Sales" asp-controller="Refund" asp-action="MyRefunds">Moje zwroty</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Customer" asp-action="Index">Dane kontaktowe</a>
                                    <div class="dropdown-divider"></div>
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                        <button type="submit" class="dropdown-item btn btn-link">Wyloguj</button>
                                    </form>
                                }
                                else
                                {
                                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login">Logowanie</a>
                                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register">Rejestracja</a>
                                }
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom">
            <div class="container">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#secondaryNavCollapse"
                        aria-controls="secondaryNavCollapse" aria-expanded="false" aria-label="Toggle secondary navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="secondaryNavCollapse">
                    @if (isMaintenanceRole)
                    {
                        <ul class="navbar-nav gap-2">
                            @if (isManagingRole)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Sales" asp-controller="Coupon" asp-action="Index"><i class="fa-solid fa-ticket me-1"></i>Kupony</a>
                                </li>
                            }
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown"><i class="fa-solid fa-box-open me-1"></i>Katalog</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-area="" asp-controller="Item" asp-action="Index">Produkty</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Type" asp-action="Index">Kategorie</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Tag" asp-action="Index">Tagi</a>
                                    @if (isManagingRole)
                                    {
                                        <a class="dropdown-item" asp-area="" asp-controller="Brand" asp-action="Index">Marki</a>
                                    }
                                </div>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown"><i class="fa-solid fa-warehouse me-1"></i>Magazyn</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-area="" asp-controller="Inventory" asp-action="Index">Przegląd stanu</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Inventory" asp-action="Reservations">Rezerwacje</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Inventory" asp-action="AdjustStock">Korekta stanu</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Inventory" asp-action="PendingAdjustments">Oczekujące korekty</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="Inventory" asp-action="Audit">Historia zmian</a>
                                </div>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown"><i class="fa-solid fa-truck me-1"></i>Realizacja</a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" asp-area="Sales" asp-controller="Orders" asp-action="Index">Zamówienia</a>
                                    <a class="dropdown-item" asp-area="Sales" asp-controller="Orders" asp-action="PaidOrders">Wydania</a>
                                    <a class="dropdown-item" asp-area="Sales" asp-controller="Refund" asp-action="Index">Zwroty</a>
                                </div>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown"><i class="fa-solid fa-gears me-1"></i>Zaplecze</a>
                                <div class="dropdown-menu">
                                    @if (isManagingRole)
                                    {
                                        <a class="dropdown-item" asp-area="" asp-controller="UserManagement" asp-action="Index">Użytkownicy</a>
                                        }
                                    <a class="dropdown-item" asp-area="" asp-controller="Currency" asp-action="Index">Waluty</a>
                                    <a class="dropdown-item" asp-area="" asp-controller="JobManagement" asp-action="Index">Zadania</a>
                                </div>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav gap-2">
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" data-bs-toggle="dropdown"><i class="fa-solid fa-list me-1"></i>Kategorie</a>
                                <div class="dropdown-menu">
                                    @foreach (var cat in categories)
                                    {
                                        <a class="dropdown-item" asp-area="" asp-controller="Item" asp-action="Index" asp-route-typeId="@cat.Id">@cat.Name</a>
                                    }
                                </div>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <div id="ErrorContainer" style="display: none;">
                <div class="alert alert-danger w-100">
                    <span id="ErrorValue" style="white-space: pre-line;">
                    </span>
                </div>
            </div>
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            <div class="container-fluid row">
                <div class="col text-start">
                    &copy; 2021 - 2024 - ECommerceApp.Web
                </div>

                <div class="col text-center">
                    Created by Kamil Wojtasinski
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/tom-select/js/tom-select.complete.min.js"></script>
    <script src="~/lib/require-js/require.js"></script>
    <script src="~/js/config.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>

        $(document).on('DOMInitialized', function (event, { ajaxRequest, showError, he }) {
            setGlobalError('@Context.Request.Query["Error"]', showError, he);

            var itemCount = document.getElementById("itemCount");

            if (!itemCount) {
                return;
            }

            ajaxRequest.send("/OrderItem/OrderItemCount", "GET", undefined, "application/json", "json")
                        .then(response => { 
                            if (response.count > 0) {
                                itemCount.innerHTML = response.count;
                            }
                        });
        });

        document.querySelectorAll('.category-filter-item').forEach(function (el) {
            el.addEventListener('click', function (e) {
                e.preventDefault();
                document.getElementById('searchTypeId').value = this.dataset.typeId;
                document.getElementById('categoryFilterBtn').textContent = this.textContent;
            });
        });

        function setGlobalError(error, showError, he) {
            if (!error) {
                showError();
                return;
            }

            try {
                const errorParsed = JSON.parse(he.decode(error));
                showError(errorParsed);
            } catch {
                showError();
            }
        }

        $.validator.methods.range = function (value, element, param) {
            var globalizedValue = value.replace(",", ".");
            return this.optional(element) || (globalizedValue >= param[0] && globalizedValue <= param[1]);
        }

        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /-?(?:\d+|\d{1,3}(?:[\s\.,]\d{3})+)(?:[\.,]\d+)?$/.test(value);
        }
        //Date dd/MM/yyyy
        $.validator.methods.date = function (value, element) {
            var date = value.split("/");
            return this.optional(element) || !/Invalid|NaN/.test(new Date(date[2], date[1], date[0]).toString());
        }

        var iso4217Codes = [];
        var iso4217Message = 'Podaj prawidłowy kod waluty (np. EUR, USD, PLN).';
        $.validator.addMethod("iso4217", function (value, element) {
            return this.optional(element) || iso4217Codes.indexOf(value.toUpperCase()) >= 0;
        }, function () { return iso4217Message; });
        $.validator.unobtrusive.adapters.add("iso4217", function (options) {
            options.rules["iso4217"] = true;
        });
        require(['errors'], function (e) { iso4217Message = e.errors.getError('invalidCurrencyCode'); });
    </script>
    <style type="text/css">
        .badge.text-bg-light {
            color: #0077cc
        }

        ul {
            padding: 0;
            list-style: none;
        }
        ul li {
            display: inline-block;
            position: relative;
            line-height: 21px;
            text-align: left;
        }
        ul li a {
            display: block;
            padding: 8px 25px;
            color: #333;
            text-decoration: none;
        }
        ul li a:hover {
            color: #fff;
        }
        ul li ul.dropdown {
            min-width: 100%; /* Set width of the dropdown */
            background: #939393;
            display: none;
            position: absolute;
            z-index: 999;
            left: 0;
        }
        ul li:hover ul.dropdown {
            display: block; /* Display the dropdown */
        }
        ul li ul.dropdown li {
            display: block;
        }

        @@media (min-width: 576px) {
            .left-position {
                left: 60% !important;
            }
        }

        .left-position {
            left: 50%;
        }

        .top-0 {
            top: 0 !important;
        }

        @@media (max-width: 1200px) {
            .wrap-items {
                flex-wrap: wrap;
            }
        }

        .navbar-title-app {
            white-space: normal;
            text-align: center;
            word-break: normal !important;
        }

    </style>
    @RenderSection("Scripts", required: false)
</body>
</html>
