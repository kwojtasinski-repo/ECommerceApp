@model StorefrontProductListVm
@{
    ViewData["Title"] = $"Produkty: {ViewBag.TagName}";
    var totalPages = Model.TotalCount == 0 ? 1 : (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    int tagId = ViewBag.TagId;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            <i class="fa-solid fa-tag me-2"></i>@ViewBag.TagName
            <span class="text-muted fs-6 ms-2">(@Model.TotalCount produktów)</span>
        </h2>
        <a asp-area="Presale" asp-controller="Storefront" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Wszystkie produkty
        </a>
    </div>

    @if (Model.Products.Count == 0)
    {
        <p class="text-muted">Brak produktów dla tego tagu.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Price.ToString("C")</p>
                            @if (product.InStock)
                            {
                                <span class="badge bg-success">Dostępny</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Niedostępny</span>
                            }
                        </div>
                        <div class="card-footer bg-transparent p-2">
                            <div class="d-grid gap-1">
                                <a asp-area="Presale" asp-controller="Storefront" asp-action="Details" asp-route-id="@product.ProductId"
                                   class="btn btn-outline-primary btn-sm">Szczegóły</a>
                                @if (product.InStock)
                                {
                                    <form asp-area="Presale" asp-controller="Checkout" asp-action="AddToCart" method="post"
                                          class="js-add-to-cart-form">
                                        <input type="hidden" name="productId" value="@product.ProductId" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn btn-primary btn-sm w-100">
                                            <i class="fa-solid fa-cart-plus me-1"></i>Do koszyka
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a asp-area="Presale" asp-controller="Storefront" asp-action="ByTag"
                           asp-route-tagId="@tagId" asp-route-pageSize="@Model.PageSize" asp-route-pageNo="@i"
                           class="page-link">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        $(document).on('DOMInitialized', function (event, { cartNotification }) {
            cartNotification.bindCartForms();
        });
    </script>
}
