@model ECommerceApp.Application.Presale.Checkout.ViewModels.CartVm?

@{
    ViewData["Title"] = "Koszyk";
}

<h1>Koszyk</h1>

@if (Model == null || Model.Lines.Count == 0)
{
    <p><em>Twój koszyk jest pusty.</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Produkt</th>
                <th>Ilość</th>
                <th>Akcja</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in Model.Lines)
            {
                <tr>
                    <td>@(line.ProductName ?? line.ProductId.ToString())</td>
                    <td>@line.Quantity</td>
                    <td>
                        <form asp-area="Presale" asp-controller="Checkout" asp-action="DeleteCartItem" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@line.ProductId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-area="Presale" asp-controller="Checkout" asp-action="PlaceOrder" class="btn btn-primary">Przejdź do zamówienia</a>
    </div>
}
