@model System.Collections.Generic.List<TagWithUsageVm>
@{
    ViewData["Title"] = "Tagi";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fa-solid fa-tags me-2"></i>Tagi</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i>Dodaj tag</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Nazwa</th>
                    <th>Slug</th>
                    <th>Produkty</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    <tr>
                        <td>@tag.Name</td>
                        <td>@tag.Slug</td>
                        <td>@tag.TotalProductCount</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@tag.Id" class="btn btn-outline-warning btn-sm">Edytuj</a>
                            <form asp-action="Delete" asp-route-id="@tag.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Czy na pewno usunąć tag?')">Usuń</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
