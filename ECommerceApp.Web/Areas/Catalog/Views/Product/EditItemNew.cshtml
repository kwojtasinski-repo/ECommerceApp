@model UpdateProductFormVm
@{
    ViewData["Title"] = "Edytuj produkt";
    var productId = (int)ViewBag.ProductId;
    var categories = ViewBag.Categories as System.Collections.Generic.List<CategoryVm> ?? new System.Collections.Generic.List<CategoryVm>();
    var images = ViewBag.Images as System.Collections.Generic.List<ProductImageVm> ?? new System.Collections.Generic.List<ProductImageVm>();
}

<div class="container mt-4">
    <h2><i class="fa-solid fa-box-open me-2"></i>Edytuj produkt</h2>

    <div class="row">
        <div class="col-md-6">
            <form id="formEditProduct" asp-action="Edit" asp-route-id="@productId" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="alert alert-danger d-none" id="validationSummary"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Nazwa</label>
                    <input id="ProductNameInput" asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Cost" class="form-label">Cena</label>
                    <input id="ProductCostInput" asp-for="Cost" type="number" step="0.01" class="form-control" />
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Opis</label>
                    <textarea id="ProductDescriptionInput" asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">Kategoria</label>
                    <select id="ProductCategorySelect" asp-for="CategoryId" class="form-select">
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Tags" class="form-label">Tagi (oddziel przecinkami)</label>
                    <input asp-for="Tags" class="form-control" placeholder="np. nowy, promocja" />
                    <span asp-validation-for="Tags" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Zapisz</button>
                    <a asp-action="Details" asp-route-id="@productId" class="btn btn-secondary">Anuluj</a>
                </div>
            </form>
        </div>

        <div class="col-md-5 offset-md-1">
            <h4>Zdjęcia</h4>

            <div id="chunkUploadWidget">
                <label for="chunkFileInput" class="form-label">Wybierz plik</label>
                <input id="chunkFileInput" type="file" class="form-control mb-2" accept="image/*" />
                <button id="chunkUploadBtn" class="btn btn-outline-secondary w-100" type="button">Wgraj</button>
                <div class="progress mt-2 d-none" id="chunkProgressWrapper">
                    <div id="chunkProgressBar" class="progress-bar" role="progressbar" style="width:0%">0%</div>
                </div>
                <div id="chunkUploadError" class="text-danger mt-1 d-none"></div>
            </div>

            @if (images.Count > 0)
            {
                <div class="mt-3" id="imageGallery">
                    @foreach (var img in images)
                    {
                        <div class="card mb-2" style="max-width:18rem;" data-name="ItemImage">
                            <div class="card-body p-2">
                                <button class="btn btn-sm btn-danger ms-auto d-block mb-1" onclick="DeleteImage(@img.Id)">Usuń</button>
                                <img src="@img.Url" class="img-fluid rounded" style="max-height:200px;" />
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div id="imageGallery" class="mt-3"></div>
            }
        </div>
    </div>
</div>

@section PreScripts {
    <partial name="_ValidationScriptsPartial" />
}

@section Scripts {
    <script>
        (function () {
            var s = document.getElementById('validationSummary');
            if (s && s.querySelectorAll('li').length > 0) s.classList.remove('d-none');
        })();

        let ajaxRequest, modalService, statusCodes, showError, showErrorFromResponse;

        $(document).on('DOMInitialized', function (event, mods) {
            ({ ajaxRequest, modalService, statusCodes, showError, showErrorFromResponse } = mods);
            new TomSelect('#ProductCategorySelect');
        });

        document.getElementById('chunkUploadBtn').addEventListener('click', async function () {
            const fileInput = document.getElementById('chunkFileInput');
            const file = fileInput.files[0];
            if (!file) return;

            const errorEl = document.getElementById('chunkUploadError');
            errorEl.classList.add('d-none');
            errorEl.textContent = '';

            const progressWrapper = document.getElementById('chunkProgressWrapper');
            const progressBar = document.getElementById('chunkProgressBar');
            progressWrapper.classList.remove('d-none');
            progressBar.style.width = '0%';
            progressBar.textContent = '0%';

            const aft = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                     ?? document.cookie.split('; ').find(r => r.startsWith('XSRF-TOKEN='))?.split('=')[1]
                     ?? '';

            let sessionId, chunkSize, totalChunks, chunkIds;
            try {
                const initRes = await fetch('/Catalog/Image/InitUpload', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': aft },
                    body: JSON.stringify({ fileName: file.name, fileSizeBytes: file.size, itemId: @productId })
                });
                if (!initRes.ok) throw new Error('Błąd inicjalizacji uploadu.');
                ({ sessionId, chunkSize, totalChunks, chunkIds } = await initRes.json());
            } catch (e) {
                showUploadError(e.message || 'Błąd inicjalizacji uploadu.');
                return;
            }

            for (const chunkId of chunkIds) {
                const start = (chunkId - 1) * chunkSize;
                const slice = file.slice(start, start + chunkSize);
                const fd = new FormData();
                fd.append('sessionId', sessionId);
                fd.append('chunkId', chunkId);
                fd.append('chunk', slice, file.name);
                fd.append('__RequestVerificationToken', aft);
                let res;
                try {
                    const chunkRes = await fetch('/Catalog/Image/UploadChunk', { method: 'POST', body: fd });
                    if (!chunkRes.ok) throw new Error('Błąd uploadu fragmentu ' + chunkId + '.');
                    res = await chunkRes.json();
                } catch (e) {
                    showUploadError(e.message || 'Błąd uploadu.');
                    return;
                }

                const pct = Math.round(res.receivedCount / totalChunks * 100);
                progressBar.style.width = pct + '%';
                progressBar.textContent = pct + '%';

                if (res.complete) {
                    fileInput.value = '';
                    window.location.reload();
                    break;
                }
            }
        });

        async function DeleteImage(id) {
            const result = await modalService.showConfirmationModal('Usuń zdjęcie', 'Czy na pewno chcesz usunąć zdjęcie?');
            if (!result) return;
            var url = '/Catalog/Image/DeleteImage/' + parseInt(id);
            try {
                await ajaxRequest.send(url, 'DELETE');
                window.location.reload();
            } catch (error) {
                if (error.status === statusCodes.Unauthorized) window.location.href = 'Identity/Account/Login';
                else if (error.status === statusCodes.InternalErrorServer) showError([{ code: 'generalError' }]);
                else showErrorFromResponse(error);
            }
        }

        function showUploadError(msg) {
            const el = document.getElementById('chunkUploadError');
            el.textContent = msg;
            el.classList.remove('d-none');
            document.getElementById('chunkProgressWrapper').classList.add('d-none');
        }
    </script>
}
