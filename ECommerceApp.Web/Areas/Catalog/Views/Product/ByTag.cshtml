@model ProductListVm
@{
    ViewData["Title"] = $"Produkty: {ViewBag.TagName}";
    var totalPages = Model.Count == 0 ? 1 : (int)Math.Ceiling((double)Model.Count / Model.PageSize);
    int tagId = ViewBag.TagId;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            <i class="fa-solid fa-tag me-2"></i>@ViewBag.TagName
            <span class="text-muted fs-6 ms-2">(@Model.Count produktów)</span>
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fa-solid fa-arrow-left me-1"></i>Wszystkie produkty
        </a>
    </div>

    @if (Model.Products.Count == 0)
    {
        <p class="text-muted">Brak produktów dla tego tagu.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Cost.ToString("C")</p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm">Szczegóły</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a asp-action="ByTag" asp-route-tagId="@tagId"
                           asp-route-pageSize="@Model.PageSize" asp-route-pageNo="@i"
                           class="page-link">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
