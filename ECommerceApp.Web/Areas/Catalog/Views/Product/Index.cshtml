@model ProductListVm
@{
    ViewData["Title"] = "Produkty";
    var totalPages = Model.Count == 0 ? 1 : (int)Math.Ceiling((double)Model.Count / Model.PageSize);
}

<div class="container mt-4">
    <h2><i class="fa-solid fa-box-open me-2"></i>Produkty</h2>

    <form method="post" class="row g-2 mb-3">
        <div class="col-auto">
            <select name="pageSize" class="form-select">
                @foreach (var s in new[] { 12, 24, 48 })
                {
                    <option value="@s" selected="@(Model.PageSize == s)">@s</option>
                }
            </select>
        </div>
        <div class="col">
            <input name="searchString" type="text" class="form-control" placeholder="Szukaj..." value="@Model.SearchString" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary">Szukaj</button>
        </div>
        <input type="hidden" name="pageNo" value="1" />
    </form>

    @if (Model.Products.Count == 0)
    {
        <p class="text-muted">Brak produktów.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted">@product.Cost.ToString("C")</p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm">Szczegóły</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <form method="post" class="d-inline">
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="pageNo" value="@i" />
                            <input type="hidden" name="searchString" value="@Model.SearchString" />
                            <button type="submit" class="page-link">@i</button>
                        </form>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
