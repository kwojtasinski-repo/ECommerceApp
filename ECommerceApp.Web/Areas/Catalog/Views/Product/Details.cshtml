@model ProductDetailsVm
@{
    ViewData["Title"] = Model.Name;
    bool isAdmin = User.IsInRole("Administrator") || User.IsInRole("Manager") || User.IsInRole("Service");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@Model.Name</h2>
        @if (isAdmin)
        {
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">Edytuj</a>
                @if (Model.Status == "Published")
                {
                    <form asp-action="Unpublish" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary">Cofnij publikację</button>
                    </form>
                }
                else
                {
                    <form asp-action="Publish" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">Opublikuj</button>
                    </form>
                }
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger"
                            onclick="return confirm('Czy na pewno usunąć produkt?')">Usuń</button>
                </form>
            </div>
        }
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Cena</dt>
                <dd class="col-sm-9">@Model.Cost.ToString("C")</dd>

                <dt class="col-sm-3">Kategoria</dt>
                <dd class="col-sm-9">@Model.CategoryName</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.Status == "Published")
                    {
                        <span class="badge bg-success">Opublikowany</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Szkic</span>
                    }
                </dd>

                <dt class="col-sm-3">Opis</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                @if (Model.TagNames.Count > 0)
                {
                    <dt class="col-sm-3">Tagi</dt>
                    <dd class="col-sm-9">
                        @foreach (var tag in Model.TagNames)
                        {
                            <span class="badge bg-secondary me-1">@tag</span>
                        }
                    </dd>
                }
            </dl>
        </div>
    </div>

    @if (Model.Images.Count > 0)
    {
        <div class="row g-2 mb-3">
            @foreach (var img in Model.Images)
            {
                <div class="col-auto">
                    <img src="@img.Url" alt="@Model.Name" class="img-thumbnail" style="max-height:150px;" />
                </div>
            }
        </div>
    }

    <a asp-action="All" class="btn btn-secondary">Wróć</a>
</div>
