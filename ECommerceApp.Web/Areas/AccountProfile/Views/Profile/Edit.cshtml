@model EditProfileFormVm
@{
    ViewData["Title"] = "Edytuj dane profilu";
}

<h1 class="h3 mb-4">Edytuj dane profilu</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@ViewBag.ProfileId" method="post">
            <div class="mb-3">
                <label asp-for="FirstName" class="form-label">Imię</label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LastName" class="form-label">Nazwisko</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsCompany" class="form-check-input" type="checkbox" id="isCompanyCheck" />
                <label class="form-check-label" for="isCompanyCheck">Firma</label>
            </div>
            <div id="companyFields">
                <div class="mb-3">
                    <label asp-for="CompanyName" class="form-label">Nazwa firmy</label>
                    <input asp-for="CompanyName" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Nip" class="form-label">NIP</label>
                    <input asp-for="Nip" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Zapisz</button>
                <a asp-action="Details" asp-route-id="@ViewBag.ProfileId" class="btn btn-outline-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var chk = document.getElementById('isCompanyCheck');
            var fields = document.getElementById('companyFields');
            fields.style.display = chk.checked ? '' : 'none';
            chk.addEventListener('change', function () {
                fields.style.display = chk.checked ? '' : 'none';
            });
        })();
    </script>
}
