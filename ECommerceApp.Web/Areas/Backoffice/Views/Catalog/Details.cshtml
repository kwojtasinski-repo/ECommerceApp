@model ECommerceApp.Application.Backoffice.ViewModels.BackofficeCatalogDetailVm

@{
    ViewData["Title"] = "Szczegóły produktu";
}

<h1>Szczegóły produktu</h1>

<dl class="row">
    <dt class="col-sm-3">Id</dt>
    <dd class="col-sm-9">@Model.Id</dd>

    <dt class="col-sm-3">Nazwa</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Cena</dt>
    <dd class="col-sm-9">@Model.Cost.ToString("N2")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Id kategorii</dt>
    <dd class="col-sm-9">@Model.CategoryId</dd>

    <dt class="col-sm-3">Kategoria</dt>
    <dd class="col-sm-9">@Model.CategoryName</dd>
</dl>

<a asp-area="Backoffice" asp-controller="Catalog" asp-action="Index">← Wróć do listy</a>
