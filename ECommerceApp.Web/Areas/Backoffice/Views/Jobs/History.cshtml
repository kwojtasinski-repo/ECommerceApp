@model ECommerceApp.Application.Backoffice.ViewModels.BackofficeJobListVm

@{
    ViewData["Title"] = "Backoffice — Historia zadań";
}

<h1>Historia zadań</h1>

<a asp-area="Backoffice" asp-controller="Jobs" asp-action="Index" class="btn btn-outline-secondary mb-3">Zadania</a>

<form asp-area="Backoffice" asp-controller="Jobs" asp-action="History" method="post">
    <div class="input-group mb-3">
        <input type="number" name="pageSize" value="@Model.PageSize" class="form-control" style="max-width:80px;" placeholder="Rozmiar strony" />
        <input type="number" name="pageNo" value="@Model.CurrentPage" class="form-control" style="max-width:80px;" placeholder="Strona" />
        <button type="submit" class="btn btn-outline-secondary">Filtruj</button>
    </div>
</form>

@if (!Model.Jobs.Any())
{
    <p><em>Brak historii zadań.</em></p>
}
else
{
    var pageCount = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize) : 1;
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nazwa</th>
                <th>Status</th>
                <th>Ostatnie uruchomienie</th>
                <th>Następne uruchomienie</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Jobs)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Status</td>
                    <td>@item.LastRunAt</td>
                    <td>@item.NextRunAt</td>
                </tr>
            }
        </tbody>
    </table>

    @if (pageCount > 1)
    {
        <nav>
            <ul class="pagination">
                @for (int i = 1; i <= pageCount; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <form asp-area="Backoffice" asp-controller="Jobs" asp-action="History" method="post" class="d-inline">
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />
                            <input type="hidden" name="pageNo" value="@i" />
                            <button type="submit" class="page-link">@i</button>
                        </form>
                    </li>
                }
            </ul>
        </nav>
    }
}
