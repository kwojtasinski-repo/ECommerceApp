@model ECommerceApp.Application.Sales.Coupons.DTOs.CreateCouponDto
@{
    ViewData["Title"] = "Dodaj kupon";
}

<div class="container mt-4" style="max-width:600px;">
    <h2><i class="fa-solid fa-ticket me-2"></i>Dodaj kupon</h2>

    <form method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="alert alert-danger d-none" id="validationSummary"></div>

        <div class="mb-3">
            <label asp-for="Code" class="form-label">Kod</label>
            <input asp-for="Code" class="form-control" placeholder="np. SUMMER20" required />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Opis</label>
            <input asp-for="Description" class="form-control" required />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="RulesJson" class="form-label">Reguły (JSON)</label>
            <textarea asp-for="RulesJson" class="form-control" rows="5" required
                      placeholder='[{"Name":"percentage-off","Category":"Discount","Parameters":{"percent":"10"}}]'></textarea>
            <span asp-validation-for="RulesJson" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Dodaj</button>
            <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
        </div>
    </form>
</div>

@section PreScripts {
    <partial name="_ValidationScriptsPartial" />
}

@section Scripts {
    <script>
        (function () {
            var s = document.getElementById('validationSummary');
            if (s && s.querySelectorAll('li').length > 0) s.classList.remove('d-none');
        })();
    </script>
}
