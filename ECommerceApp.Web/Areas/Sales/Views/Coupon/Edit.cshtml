@model ECommerceApp.Application.Sales.Coupons.DTOs.UpdateCouponDto
@{
    ViewData["Title"] = "Edytuj kupon";
}

<div class="container mt-4" style="max-width:600px;">
    <h2><i class="fa-solid fa-ticket me-2"></i>Edytuj kupon</h2>

    <form method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label asp-for="Code" class="form-label">Kod</label>
            <input asp-for="Code" class="form-control" required />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Opis</label>
            <input asp-for="Description" class="form-control" required />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Zapisz</button>
            <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
