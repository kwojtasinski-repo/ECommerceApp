@model ECommerceApp.Application.Sales.Coupons.ViewModels.CouponDetailVm
@{
    ViewData["Title"] = "Szczegóły kuponu";
}

<div class="container mt-4" style="max-width:700px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fa-solid fa-ticket me-2"></i>Szczegóły kuponu</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning me-1">Edytuj</a>
            <a asp-action="Index" class="btn btn-secondary">Wróć</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4">Kod</dt>
                <dd class="col-sm-8"><strong>@Model.Code</strong></dd>

                <dt class="col-sm-4">Opis</dt>
                <dd class="col-sm-8">@Model.Description</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">
                    @if (Model.Status == "Available")
                    {
                        <span class="badge bg-success">Dostępny</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Użyty</span>
                    }
                </dd>

                @if (!string.IsNullOrWhiteSpace(Model.RulesJson))
                {
                    <dt class="col-sm-4">Reguły (JSON)</dt>
                    <dd class="col-sm-8">
                        <pre class="bg-light p-2 rounded small" style="max-height:200px;overflow:auto;">@Model.RulesJson</pre>
                    </dd>
                }
            </dl>
        </div>
    </div>
</div>
