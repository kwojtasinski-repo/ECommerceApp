@model ECommerceApp.Application.Sales.Coupons.ViewModels.CouponListVm
@{
    ViewData["Title"] = "Kupony";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fa-solid fa-ticket me-2"></i>Kupony</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="fa-solid fa-plus me-1"></i>Dodaj kupon</a>
    </div>

    <form method="post" class="row g-2 mb-3">
        <div class="col-auto">
            <select name="pageSize" class="form-select">
                @foreach (var s in new[] { 10, 20, 50 })
                {
                    <option value="@s" selected="@(Model.PageSize == s)">@s</option>
                }
            </select>
        </div>
        <div class="col">
            <input name="searchString" type="text" class="form-control" placeholder="Szukaj..." value="@Model.SearchString" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary">Szukaj</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Kod</th>
                    <th>Opis</th>
                    <th>Rabat (%)</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Coupons)
                {
                    <tr>
                        <td><strong>@c.Code</strong></td>
                        <td>@c.Description</td>
                        <td>@c.DiscountPercent</td>
                        <td>
                            @if (c.Status == "Available")
                            {
                                <span class="badge bg-success">Dostępny</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Użyty</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info me-1">Podgląd</a>
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-warning me-1">Edytuj</a>
                            <form method="post" asp-action="Delete" asp-route-id="@c.Id" class="d-inline"
                                  onsubmit="return confirm('Usunąć kupon @c.Code?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Coupons.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted">Brak kuponów.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <small class="text-muted">Łącznie: @Model.TotalCount</small>
        @{
            var totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize) : 1;
        }
        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination mb-0">
                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                            <form method="post" class="d-inline">
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <input type="hidden" name="pageNo" value="@p" />
                                <input type="hidden" name="searchString" value="@Model.SearchString" />
                                <button type="submit" class="page-link">@p</button>
                            </form>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
