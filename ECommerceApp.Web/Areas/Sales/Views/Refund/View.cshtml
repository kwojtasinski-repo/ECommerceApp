@model RefundDetailsVm

@{
    ViewData["Title"] = "Szczegóły zwrotu";
}

<h1>Szczegóły zwrotu</h1>

<dl class="row">
    <dt class="col-sm-3">Id</dt>
    <dd class="col-sm-9">@Model.Id</dd>

    <dt class="col-sm-3">Id zamówienia</dt>
    <dd class="col-sm-9">
        <a asp-area="Sales" asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderId">@Model.OrderId</a>
    </dd>

    <dt class="col-sm-3">Powód</dt>
    <dd class="col-sm-9">@Model.Reason</dd>

    <dt class="col-sm-3">Gwarancja</dt>
    <dd class="col-sm-9">@(Model.OnWarranty ? "Tak" : "Nie")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Data zgłoszenia</dt>
    <dd class="col-sm-9">@Model.RequestedAt.ToString("dd.MM.yyyy HH:mm")</dd>

    @if (Model.ProcessedAt.HasValue)
    {
        <dt class="col-sm-3">Data rozpatrzenia</dt>
        <dd class="col-sm-9">@Model.ProcessedAt.Value.ToString("dd.MM.yyyy HH:mm")</dd>
    }
</dl>

@if (Model.Items != null && Model.Items.Count > 0)
{
    <h4>Pozycje zwrotu</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Id produktu</th>
                <th>Ilość</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.Quantity</td>
                </tr>
            }
        </tbody>
    </table>
}

<div>
    <a asp-area="Sales" asp-controller="Refund" asp-action="MyRefunds">Moje zwroty</a>
</div>
