@model ECommerceApp.Application.Sales.Orders.ViewModels.OrderItemListVm

@{
    ViewData["Title"] = "Pozycje zamówień";
}

<h1>Pozycje zamówień</h1>

<form asp-area="Sales" asp-controller="OrderItems" asp-action="Index" method="post">
    <div class="input-group mb-3">
        <input type="number" name="pageSize" value="@Model.PageSize" class="form-control" style="max-width:80px;" placeholder="Rozmiar strony" />
        <input type="number" name="pageNo" value="@Model.CurrentPage" class="form-control" style="max-width:80px;" placeholder="Strona" />
        <input type="text" name="searchString" value="@Model.SearchString" class="form-control" placeholder="Wyszukaj..." />
        <button type="submit" class="btn btn-outline-secondary">Wyszukaj</button>
    </div>
</form>

@if (Model.Items == null || Model.Items.Count == 0)
{
    <p><em>Brak pozycji zamówień.</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Produkt</th>
                <th>Ilość</th>
                <th>Cena jedn.</th>
                <th>Id zamówienia</th>
                <th>Akcja</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@(item.ProductName ?? item.ItemId.ToString())</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitCost.ToString("N2")</td>
                    <td>
                        @if (item.OrderId.HasValue)
                        {
                            <a asp-area="Sales" asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId">@item.OrderId</a>
                        }
                    </td>
                    <td>
                        <a asp-area="Sales" asp-controller="OrderItems" asp-action="Details" asp-route-id="@item.Id">Szczegóły</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-area="Sales" asp-controller="OrderItems" asp-action="Index"
                       asp-route-pageNo="@i" asp-route-pageSize="@Model.PageSize" asp-route-searchString="@Model.SearchString">@i</a>
                </li>
            }
        </ul>
    </nav>
}
