{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ECommerceApp;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=False;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Google": {
      "ClientId": "ClientId",
      "ClientSecret": "ClientSecret"
    }
  },
  "Database": {
    "RunMigrationsOnStart": "true"
  },
  "MessagingOptions": {
    "UseBackgroundDispatcher": true
  },
  "Inventory": {
    "SoftHoldTtl": "00:15:00"
  },
  "Cache": {
    "CatalogListTtl": "00:00:15",
    "CatalogProductTtl": "00:02:00",
    "CatalogNavigationTtl": "00:15:00",
    "ProductDetailsTtl": "00:05:00",
    "CurrencyRateLatestTtl": "01:00:00",
    "CurrencyRateHistoricalTtl": "1.00:00:00",
    "StorefrontIndexTtlSeconds": 60
  },
  "Catalog": {
    "UseChunkedUpload": true
  },
  "Presale": {
    "SoftReservationTtl": "00:15:00"
  },
  "Images": {
    "BaseUrl": "https://localhost:49611",
    "BasePath": "/catalog/images"
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "UserName": "",
    "Password": "",
    "FromAddress": "",
    "FromName": ""
  }
}
