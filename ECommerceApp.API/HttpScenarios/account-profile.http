### ============================================================
### Account Profile — Customers + Addresses
### Base URL: https://localhost:49609
###
### GET {id}  — own profile (userId scoped) or admin
### POST/PUT  — any authenticated (own data)
### Addresses — POST /api/addresses, PUT /api/addresses/{profileId},
###             DELETE /api/addresses/{profileId}/{addressId}
### ============================================================

@baseUrl = https://localhost:49609
@token = YOUR_JWT_TOKEN
@contentType = application/json

# ============================================================
# AUTH
# ============================================================

### Login as admin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "admin@localhost",
  "password": "aDminN@W25!"
}

###

# ============================================================
# CUSTOMER PROFILES — /api/customers
# ============================================================

### Get profile by id (own-scoped)
# Expected: 200 OK  →  UserProfileVm | 404 if not found / not owned
GET {{baseUrl}}/api/customers/1
Authorization: Bearer {{token}}
###

### Get profile — not found
# Expected: 404 Not Found
GET {{baseUrl}}/api/customers/99999
Authorization: Bearer {{token}}
###

### Create profile
# Expected: 201 Created  →  { "id": <newId> }
# Replace userId with a real ApplicationUser.Id from the IAM store
POST {{baseUrl}}/api/customers
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userId": "replace-with-real-user-guid",
  "firstName": "Jan",
  "lastName": "Kowalski",
  "isCompany": false,
  "nip": null,
  "companyName": null,
  "email": "jan.kowalski@example.com",
  "phoneNumber": "+48600100200"
}
###

### Create profile — company
# Expected: 201 Created
POST {{baseUrl}}/api/customers
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userId": "replace-with-real-user-guid",
  "firstName": "Anna",
  "lastName": "Nowak",
  "isCompany": true,
  "nip": "1234567890",
  "companyName": "Nowak Sp. z o.o.",
  "email": "anna.nowak@firma.pl",
  "phoneNumber": "+48700200300"
}
###

### Update personal info
# Expected: 200 OK
PUT {{baseUrl}}/api/customers/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "id": 1,
  "firstName": "Jan",
  "lastName": "Kowalski-Updated",
  "isCompany": false,
  "nip": null,
  "companyName": null
}
###

### Update profile — id mismatch (route id vs body id)
# Expected: 400 Bad Request  →  { "error": "Id mismatch." }
PUT {{baseUrl}}/api/customers/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "id": 99,
  "firstName": "Bad",
  "lastName": "Request",
  "isCompany": false,
  "nip": null,
  "companyName": null
}
###

# ============================================================
# ADDRESSES — /api/addresses
# ============================================================

### Add address to profile
# Expected: 201 Created
POST {{baseUrl}}/api/addresses
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userProfileId": 1,
  "street": "ul. Marszałkowska",
  "buildingNumber": "10",
  "flatNumber": 5,
  "zipCode": "00-001",
  "city": "Warszawa",
  "country": "PL"
}
###

### Add address — no flat number
# Expected: 201 Created
POST {{baseUrl}}/api/addresses
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "userProfileId": 1,
  "street": "ul. Krakowska",
  "buildingNumber": "22A",
  "flatNumber": null,
  "zipCode": "30-001",
  "city": "Kraków",
  "country": "PL"
}
###

### Update address
# Expected: 200 OK
PUT {{baseUrl}}/api/addresses/1
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "addressId": 1,
  "street": "ul. Nowy Świat",
  "buildingNumber": "5",
  "flatNumber": null,
  "zipCode": "00-002",
  "city": "Warszawa",
  "country": "PL"
}
###

### Remove address
# Expected: 204 No Content
DELETE {{baseUrl}}/api/addresses/5/8
Authorization: Bearer {{token}}
###
